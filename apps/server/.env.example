PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/royal-suites

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Nodemailer (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL="Royal Suites <noreply@royalsuites.com>"

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Staff registration invite code
INVITE_CODE=your_invite_code_here

# MongoDB Atlas archive cluster (used by backup scripts only, not the app)
ARCHIVE_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/
